# ─── Docker Build Context Exclusions ─────────────────────────────────────────
# Keep the build context small — speeds up docker build and avoids leaking secrets

# Dependencies (reinstalled inside container)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js build output (generated inside container)
.next
out

# Environment files — NEVER bake secrets into images
.env
.env.*
!.env.example

# Development / tooling
.git
.gitignore
.github
.husky
.eslintrc*
.prettierrc*
.editorconfig
*.md
!prisma/README.md

# Test output
coverage
.nyc_output
jest.config*
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx

# OS / IDE artifacts
.DS_Store
Thumbs.db
.idea
.vscode
*.swp
*.swo

# Docker files themselves (already in context)
Dockerfile*
docker-compose*
.dockerignore

# Logs
logs
*.log

# Certificates (managed by Kubernetes secrets / AWS ACM in prod)
certs
*.pem
*.key
*.crt
