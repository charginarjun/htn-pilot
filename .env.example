# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://htn_user:password@localhost:5432/htn_pilot_dev"
DATABASE_URL_POOL="postgresql://htn_user:password@localhost:6432/htn_pilot_dev" # PgBouncer

# ─── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-64-char-random-string-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── AI — Anthropic Claude ──────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
# Model to use for clinical assessments (claude-opus-4 for production accuracy)
ANTHROPIC_MODEL="claude-opus-4-8"
# Fallback model for lower-priority tasks
ANTHROPIC_MODEL_FAST="claude-haiku-4-5-20251001"

# ─── Redis (BullMQ job queue) ────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── AWS S3 (imaging/lab document storage) ──────────────────────────────────
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."
AWS_S3_BUCKET="htn-pilot-documents"
AWS_S3_REGION="us-east-1"

# ─── EPIC FHIR Integration (future) ─────────────────────────────────────────
EPIC_FHIR_BASE_URL="https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4"
EPIC_CLIENT_ID=""
EPIC_PRIVATE_KEY_PATH="./certs/epic-private-key.pem"
EPIC_FHIR_ENABLED="false"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="HTN Pilot"
NODE_ENV="development"

# ─── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="100"

# ─── Encryption (PII at-rest) ────────────────────────────────────────────────
FIELD_ENCRYPTION_KEY="change-me-to-a-32-byte-aes-key-base64"
