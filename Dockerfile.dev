# ─── HTN Pilot — Development Dockerfile ──────────────────────────────────────
# Hot reload enabled. Not for production use.

FROM node:20-alpine

RUN apk add --no-cache libc6-compat openssl curl

WORKDIR /app

COPY package.json package-lock.json ./
COPY prisma ./prisma/

RUN npm ci

RUN npx prisma generate

EXPOSE 3000

CMD ["npm", "run", "dev"]
